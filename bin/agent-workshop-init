#!/usr/bin/env bash
#
# agent-workshop-init — Initialize the workshop in the current project
#
# Detects the coding agent being used and creates the right instruction file
# so the agent automatically knows how to run workshops.
#
# Usage: agent-workshop-init [claude|cursor|pi|generic]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}ℹ${NC}  $1"; }
success() { echo -e "${GREEN}✓${NC}  $1"; }
warn()    { echo -e "${YELLOW}⚠${NC}  $1"; }
error()   { echo -e "${RED}✗${NC}  $1"; }

# Resolve workshop install directory
resolve_workshop_dir() {
    if [[ -n "${WORKSHOP_DIR:-}" ]] && [[ -d "$WORKSHOP_DIR" ]]; then
        echo "$WORKSHOP_DIR"
    elif [[ -d "$HOME/.agent-workshop" ]]; then
        echo "$HOME/.agent-workshop"
    elif [[ -d "$REPO_ROOT" ]] && [[ -f "$REPO_ROOT/workshop-manifest.json" ]]; then
        echo "$REPO_ROOT"
    else
        echo ""
    fi
}

# Write Claude Code instructions
init_claude() {
    local workshop_dir="$1"
    local target="CLAUDE.md"

    if [[ ! -f "$workshop_dir/CLAUDE.md" ]]; then
        error "CLAUDE.md not found in $workshop_dir. Is agent-workshop installed?"
        exit 1
    fi

    cp "$workshop_dir/CLAUDE.md" "$target"
    success "Copied CLAUDE.md from $workshop_dir → ./CLAUDE.md"
    info "Claude Code will auto-load these instructions for this project."
    info "Say 'run a workshop for building X' to start."
    echo ""
    info "To update when the workshop protocol changes: re-run the installer, then re-init"
    info "  curl -fsSL https://raw.githubusercontent.com/baljeet/agent-workshop/main/install.sh | bash"
    info "  agent-workshop init claude"
}

# Write Cursor rules  
init_cursor() {
    local workshop_dir="$1"
    local target=".cursor/rules.md"
    mkdir -p ".cursor"

    # Cursor rules: reference the workshop install, let the agent load from there
    cat > "$target" << INSTRUCTIONS
# Multi-Agent Design Workshop — Cursor Rules

When the user says **"run a workshop"**, **"design a workshop"**, or **"multi-agent design"**, follow this protocol.

## Setup

Read the workshop instructions from the installed repo:

\`\`\`bash
WORKSHOP_DIR="${WORKSHOP_DIR:-$HOME/.agent-workshop}"
cat "\$WORKSHOP_DIR/workshop-manifest.json"
cat "\$WORKSHOP_DIR/docs/protocol.md"
cat "\$WORKSHOP_DIR/docs/prompts/workshop-charter.md"
cat "\$WORKSHOP_DIR/SKILL.md"   # Full facilitation guide
\`\`\`

## Execution

You are **Facilitator + All Agent Roles**. Execute P1-P8 autonomously, then REVIEW agents. See SKILL.md for the complete guide. The workshop runs fully autonomous — present everything to the user once at the end.

## Update

Re-run the installer then re-init:
\`\`\`bash
curl -fsSL https://raw.githubusercontent.com/baljeet/agent-workshop/main/install.sh | bash
agent-workshop init cursor
\`\`\`
INSTRUCTIONS

    success "Created $target for Cursor"
    info "Cursor will use these rules for this project."
}

# Write generic instructions
init_generic() {
    local workshop_dir="$1"
    local target="WORKSHOP.md"

    cp "$workshop_dir/SKILL.md" "$target"
    success "Copied SKILL.md from $workshop_dir → ./WORKSHOP.md"
    info "Include this file in your agent's context to activate the workshop protocol."
}

# Main
main() {
    local agent="${1:-auto}"
    
    # Auto-detect
    if [[ "$agent" == "auto" ]] || [[ "$agent" == "--detect" ]]; then
        if [[ -n "${CLAUDE_CODE:-}" ]] || [[ -n "${ANTHROPIC_API_KEY:-}" ]] || command -v claude &>/dev/null; then
            agent="claude"
        elif [[ -d ".cursor" ]] || [[ -f ".cursorrules" ]] || [[ -n "${CURSOR_AGENT:-}" ]]; then
            agent="cursor"
        elif [[ -d ".pi" ]] || [[ -n "${PI_AGENT:-}" ]]; then
            agent="pi"
        elif [[ -n "${CODEX_AGENT:-}" ]] || [[ -d ".codex" ]]; then
            agent="generic"
        else
            agent="generic"
        fi
        info "Detected agent: $agent"
    fi

    # Resolve workshop directory
    local workshop_dir
    workshop_dir=$(resolve_workshop_dir)
    if [[ -z "$workshop_dir" ]]; then
        error "Workshop not found. Install first:"
        echo "  curl -fsSL https://raw.githubusercontent.com/baljeet/agent-workshop/main/install.sh | bash"
        exit 1
    fi
    info "Workshop source: $workshop_dir"

    case "$agent" in
        claude|claude-code|anthropic)
            init_claude "$workshop_dir"
            ;;
        cursor)
            init_cursor "$workshop_dir"
            ;;
        pi)
            info "Pi auto-detects SKILL.md. No init file needed."
            info "Ensure workshop is in ~/.agents/skills/agent-workshop/"
            info "To update: cd ~/.agents/skills/agent-workshop && git pull"
            ;;
        codex|openai|generic|default|*)
            init_generic "$workshop_dir"
            ;;
    esac
    
    echo ""
    success "Workshop initialized for: $agent"
}

main "$@"
