{
  "name": "multi-agent-design-workshop",
  "version": "2.0.0",
  "description": "Turn 'I want to build X' into a production-ready design document. 8-phase structured design workshop where the AI adopts 5-7 specialized roles, debates trade-offs, resolves objections internally, then spawns fresh review agents to critique the final doc. The user sees everything once at the end.",
  "agent_instructions": "docs/protocol.md",
  "charter": "docs/prompts/workshop-charter.md",
  "phases": [
    {
      "id": "p1",
      "name": "Problem Framing",
      "mode": "roundtable",
      "duration": "5-10 min",
      "input_from_user": "Project intent, context, constraints",
      "output_artifact": "P1 Problem Statement",
      "prompt": "docs/prompts/phase-1-problem-framing.md",
      "prompt_source": "file",
      "variables": ["PROJECT_NAME", "PROJECT_SCAN", "USER_INTENT_TEXT", "ASSIGNED_ROLE", "PROJECT_FILES_OR_NOTES"]
    },
    {
      "id": "p2",
      "name": "Requirements",
      "mode": "roundtable",
      "duration": "10-15 min",
      "input_from_user": null,
      "depends_on": "p1",
      "output_artifact": "P2 Requirements Document",
      "prompt": "template-library#p2",
      "prompt_source": "template_section",
      "variables": ["PROJECT_NAME", "P1_ARTIFACT_SUMMARY", "ASSIGNED_ROLE"]
    },
    {
      "id": "p3",
      "name": "Approach Debate",
      "mode": "roundtable",
      "duration": "15-20 min",
      "input_from_user": null,
      "depends_on": "p2",
      "output_artifact": "P3 Architecture Options + Selected Approach",
      "prompt": "template-library#p3",
      "prompt_source": "template_section",
      "variables": ["PROJECT_NAME", "P1_ARTIFACT", "P2_REQUIREMENTS_SUMMARY", "ASSIGNED_ROLE"]
    },
    {
      "id": "p4",
      "name": "System Architecture",
      "mode": "author-reviewers",
      "duration": "20-30 min",
      "input_from_user": null,
      "depends_on": "p3",
      "output_artifact": "P4 System Architecture Document",
      "prompt": "docs/prompts/phase-4-architecture-author.md",
      "prompt_source": "file",
      "variables": ["PROJECT_NAME", "P1_ARTIFACT", "P2_REQUIREMENTS", "P3_SELECTED_APPROACH", "ASSIGNED_ROLE"],
      "special": "Design Author writes; other roles review with BLOCK/CONSENT/CONCERN/QUESTION"
    },
    {
      "id": "p5",
      "name": "Component Design",
      "mode": "author-reviewers",
      "duration": "30-45 min",
      "input_from_user": null,
      "depends_on": "p4",
      "output_artifact": "P5 Component Design Document",
      "prompt": "template-library#p5",
      "prompt_source": "template_section",
      "variables": ["PROJECT_NAME", "P4_ARCHITECTURE", "COMPONENT_NAME", "ASSIGNED_ROLE"]
    },
    {
      "id": "p6",
      "name": "Error Handling",
      "mode": "author-reviewers",
      "duration": "15-20 min",
      "input_from_user": null,
      "depends_on": "p5",
      "output_artifact": "P6 Error Handling & Edge Cases",
      "prompt": "template-library#p6",
      "prompt_source": "template_section",
      "variables": ["PROJECT_NAME", "P4_ARCHITECTURE", "P5_COMPONENTS", "ASSIGNED_ROLE"]
    },
    {
      "id": "p7",
      "name": "Testing Strategy",
      "mode": "author-reviewers",
      "duration": "15-20 min",
      "input_from_user": null,
      "depends_on": "p6",
      "output_artifact": "P7 Testing & Validation Strategy",
      "prompt": "template-library#p7",
      "prompt_source": "template_section",
      "variables": ["PROJECT_NAME", "P4_ARCHITECTURE", "P5_COMPONENTS", "P6_ERRORS", "ASSIGNED_ROLE"]
    },
    {
      "id": "p8",
      "name": "Consensus",
      "mode": "roundtable",
      "duration": "10-15 min",
      "input_from_user": null,
      "depends_on": "p7",
      "output_artifact": "P8 Consensus Record + Final Design Document",
      "prompt": "docs/prompts/phase-8-consensus.md",
      "prompt_source": "file",
      "variables": ["PROJECT_NAME", "FULL_DESIGN_DOC", "ASSIGNED_ROLE"]
    },
    {
      "id": "review",
      "name": "Post-Workshop Review",
      "mode": "review-agents",
      "duration": "10-15 min",
      "input_from_user": null,
      "depends_on": "p8",
      "output_artifact": "Review Agent Feedback + Collected Questions",
      "prompt": "docs/prompts/review-agents.md",
      "prompt_source": "file",
      "variables": ["PROJECT_NAME", "FULL_DESIGN_DOC", "ASSIGNED_ROLE"],
      "special": "Fresh review agents critique the complete doc; different roles from design phases"
    }
  ],
  "roles": [
    {
      "id": "design-author",
      "name": "Design Author",
      "focus": "Architecture, interfaces, data flow, component design",
      "phases_active": ["p4", "p5", "p6", "p7"]
    },
    {
      "id": "product-critic",
      "name": "Product Critic",
      "focus": "User needs, scope creep, missing features, UX gaps",
      "phases_active": "all"
    },
    {
      "id": "security-engineer",
      "name": "Security Engineer",
      "focus": "Threat surfaces, auth gaps, data exposure, compliance",
      "phases_active": "all"
    },
    {
      "id": "scalability-engineer",
      "name": "Scalability Engineer",
      "focus": "Bottlenecks, resource limits, single points of failure",
      "phases_active": "all"
    },
    {
      "id": "integration-specialist",
      "name": "Integration Specialist",
      "focus": "API consistency, migration paths, third-party failures",
      "phases_active": ["p3", "p4", "p5"]
    },
    {
      "id": "qa-lead",
      "name": "QA/Testing Lead",
      "focus": "Testability, observability, coverage, flaky test detection",
      "phases_active": "all"
    },
    {
      "id": "devex-advocate",
      "name": "DevEx Advocate",
      "focus": "Build/debug experience, onboarding, documentation",
      "phases_active": ["p4", "p5", "p7"]
    }
  ],
  "review_agents": [
    {
      "id": "architecture-reviewer",
      "name": "Architecture Reviewer",
      "focus": "Structural integrity, gap analysis, contradiction detection",
      "phases_active": ["review"]
    },
    {
      "id": "implementation-reviewer",
      "name": "Implementation Reviewer",
      "focus": "Buildability, clarity, missing details a developer would need",
      "phases_active": ["review"]
    },
    {
      "id": "risk-reviewer",
      "name": "Risk Reviewer",
      "focus": "Production failure modes, security gaps, operational risks",
      "phases_active": ["review"]
    },
    {
      "id": "product-reviewer",
      "name": "Product Reviewer",
      "focus": "Problem-solution fit, scope alignment, user need coverage",
      "phases_active": ["review"]
    }
  ],
  "safety_protocol": {
    "signals": [
      {"signal": "BLOCK", "meaning": "Critical issue, halts progress", "action": "Agents resolve internally; if unresolvable, convert to QUESTION"},
      {"signal": "CONCERN", "meaning": "Non-blocking risk", "action": "Log it and move on"},
      {"signal": "CONSENT", "meaning": "Explicit endorsement", "action": "Required from all reviewers before synthesizing"},
      {"signal": "QUESTION", "meaning": "Needs user/customer input", "action": "Collect and present all at the end"}
    ]
  },
  "output": {
    "design_doc_sections": [
      "1. Problem Statement",
      "2. Requirements (functional + NFRs + edge cases)",
      "3. Selected Approach (with rejected alternatives)",
      "4. System Architecture (diagrams, data flow, APIs)",
      "5. Component Design (interfaces, state, dependencies)",
      "6. Error Handling & Edge Cases (failure matrix, recovery)",
      "7. Testing & Validation Strategy (pyramid, CI gates, coverage)",
      "8. Consensus Record (agent sign-offs or documented dissent)",
      "9. Workshop Metadata"
    ],
    "optional_task_list": {
      "trigger": "User asks for implementation tasks",
      "path": "docs/plans/YYYY-MM-DD-[slug]-tasks.md",
      "content": "Bite-sized tasks in dependency order with exact file paths, test-first steps, commit points (writing-plans style)",
      "sources": ["P4 architecture", "P5 component design"]
    },
    "iterative_refinement_loop": {
      "trigger": ["refine the design", "iterate", "loop", "improve the doc", "run the loop"],
      "primary_metric": "block_count",
      "metric_direction": "lower",
      "secondary_metrics": ["concern_count", "question_count"],
      "stop_conditions": [
        "0 BLOCKs (READY)",
        "3 consecutive discards (converged)",
        "BLOCK count unchanged for 2 cycles (converged)"
      ],
      "per_iteration": "Run REVIEW → fix BLOCKs in affected phases → re-run REVIEW → compare → keep/discard",
      "rules": [
        "Never re-run the entire workshop — only affected phases",
        "BLOCKs rooted in P1/P2/P3 → flag as QUESTION instead of looping",
        "Track iteration history in design doc metadata"
      ]
    },
    "checkpoints": [
      {
        "id": "requirements",
        "after_phase": "p2",
        "path": "docs/artifacts/{slug}-requirements.md",
        "content": "User stories, functional/NFR requirements with MoSCoW, edge cases"
      },
      {
        "id": "architecture-hld",
        "after_phase": "p4",
        "path": "docs/artifacts/{slug}-architecture-hld.md",
        "content": "System diagram, component overview, data flow, API surface, technology choices"
      },
      {
        "id": "architecture-lld",
        "after_phase": "p5",
        "path": "docs/artifacts/{slug}-architecture-lld.md",
        "content": "Per-component interfaces, state machines, data schemas, dependency graph"
      },
      {
        "id": "error-handling",
        "after_phase": "p6",
        "path": "docs/artifacts/{slug}-error-handling.md",
        "content": "Failure modes, recovery strategies, observability plan, retry/fallback logic"
      },
      {
        "id": "test-strategy",
        "after_phase": "p7",
        "path": "docs/artifacts/{slug}-test-strategy.md",
        "content": "Test pyramid, CI gates, coverage matrix, sample test cases per critical path"
      },
      {
        "id": "security-review",
        "after_phase": "review",
        "path": "docs/artifacts/{slug}-security-review.md",
        "content": "Threat surfaces, auth/data gaps, compliance risks, mitigation recommendations (synthesized by Risk Reviewer)"
      }
    ]
  },
  "tools": {
    "cli": "bin/agent-workshop",
    "validate": "scripts/check-readiness.sh"
  }
}
